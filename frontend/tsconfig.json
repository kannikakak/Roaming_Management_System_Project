{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "es2017"],
    "module": "commonjs",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["node"]
  },
  
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}