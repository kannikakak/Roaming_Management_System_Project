# API Configuration
REACT_APP_API_URL=http://localhost:5000

# Branding Configuration (Optional - can be customized per deployment)
# If not set, defaults will be used
REACT_APP_NAME=Roaming Management System
REACT_APP_SHORT_NAME=RMS
REACT_APP_TAGLINE=Professional Roaming & Interconnect Platform
REACT_APP_COMPANY_NAME=Your Company Name
REACT_APP_SUPPORT_EMAIL=support@roamingmanagementsystem.com

# Authentication Configuration
REACT_APP_AUTH_MODE=hybrid
REACT_APP_MICROSOFT_AUTO_REDIRECT=false

# Build Configuration
GENERATE_SOURCEMAP=false
NODE_ENV=production
